# PostgreSQL
POSTGRES_USER=bookbeam
POSTGRES_PASSWORD=bookbeam_dev
POSTGRES_DB=bookbeam

# Database connection (used by app-backend)
DATABASE_URL=postgresql://bookbeam:bookbeam_dev@postgres:5432/bookbeam

# Clerk
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# Note: EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY is also used by backend as CLERK_PUBLISHABLE_KEY (mapped in docker-compose.yml)

# Admin API bypass — full auth bypass for curl testing, workers, and agents
ADMIN_API_KEY=bookbeam-admin-dev-key
# Clerk user ID of the primary dev/test user — use with X-Admin-User-Id header for curl/agent testing
TEST_USER_ID=your_clerk_user_id

# Dev auth bypass — skips Clerk in the Expo app, uses admin headers for API calls
# Set to "true" to enable (for Playwright/agent testing)
EXPO_PUBLIC_DEV_AUTH_BYPASS=false
EXPO_PUBLIC_DEV_ADMIN_API_KEY=bookbeam-admin-dev-key
EXPO_PUBLIC_DEV_TEST_USER_ID=your_clerk_user_id

# App Backend API (from mobile device/simulator)
# Use localhost for iOS Simulator, or your Mac's local IP for physical devices (e.g. http://192.168.1.x:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000

# S3 / MinIO (file storage)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=bookbeam-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Landing page QR code URLs (set after running `eas update --branch preview`)
LANDING_QR_URL=exp+bookbeam://expo-development-client/?url=https://example.com
LANDING_IOS_QR_URL=exp://u.expo.dev/<PROJECT_ID>?channel-name=preview&runtime-version=1.0.0
LANDING_ANDROID_QR_URL=exp://u.expo.dev/<PROJECT_ID>?channel-name=preview&runtime-version=1.0.0

# LLM API (routed through LiteLLM or similar proxy)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://your-llm-endpoint

# Pipeline: Object Detection (Roboflow)
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_MODEL_ID=fyp-obb-mnsh3/9
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_TIMEOUT_SECONDS=15
ROBOFLOW_RETRIES=4

# Pipeline: OCR Backend — "llm" (Vision LLM), "mlx" (local PaddleOCR-VL), "easyocr", or "hf" (HuggingFace Inference Endpoint)
OCR_BACKEND=hf
OCR_LANGUAGES=en,es

# OCR via Vision LLM (used when OCR_BACKEND=llm)
OCR_LLM_MODEL=gemini-3.1-flash-lite-preview

# OCR via local MLX PaddleOCR-VL (used when OCR_BACKEND=mlx)
MLX_OCR_URL=http://localhost:8090
MLX_OCR_MODEL=mlx-community/PaddleOCR-VL-1.5-bf16
MLX_OCR_PORT=8090

# OCR via HuggingFace Inference Endpoint (used when OCR_BACKEND=hf)
HUGGINGFACE_API_KEY=your_hf_api_key
HF_ENDPOINT_NAME=paddleocr-vl
HF_ENDPOINT_URL=https://your-endpoint.us-east-1.aws.endpoints.huggingface.cloud

# Pipeline: LLM Models
NORMALIZATION_MODEL=gemini-3-flash-preview
NORMALIZATION_BATCH_SIZE=20
RECOMMENDATION_MODEL=gpt-5.2

# Worker concurrency
MAX_CONCURRENT_SCANS=3
