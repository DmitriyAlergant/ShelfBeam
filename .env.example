# PostgreSQL
POSTGRES_USER=bookbeam
POSTGRES_PASSWORD=bookbeam_dev
POSTGRES_DB=bookbeam

# Database connection (used by app-backend)
DATABASE_URL=postgresql://bookbeam:bookbeam_dev@postgres:5432/bookbeam

# Clerk
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# Note: EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY is also used by backend as CLERK_PUBLISHABLE_KEY (mapped in docker-compose.yml)

# App Backend API (from mobile device/simulator)
EXPO_PUBLIC_API_URL=http://localhost:3000

# LLM API
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://your-llm-endpoint
